  "query": "SELECT id, sensor_id, updated_at, data\n            FROM sensor_data\n            WHERE sensor_id = $1\n              AND ($2::timestamp IS NULL OR updated_at >= $2)\n              AND ($3::timestamp IS NULL OR updated_at <= $3)\n            ORDER BY id DESC\n            LIMIT $4 OFFSET $5",
