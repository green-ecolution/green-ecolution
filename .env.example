# Porkbun DNS API (required for Let's Encrypt certs)
# Get keys from https://porkbun.com/account/api
PORKBUN_API_KEY=
PORKBUN_SECRET_API_KEY=

# Override auto-detected local IP if needed
# LOCAL_IP=192.168.0.181

# Domain for dev environment (default: green-ecolution.dev)
# DOMAIN=green-ecolution.dev
