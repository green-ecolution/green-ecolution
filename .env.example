# Porkbun DNS API (required for Let's Encrypt certs)
# Get keys from https://porkbun.com/account/api
PORKBUN_API_KEY=
PORKBUN_SECRET_API_KEY=

# Override auto-detected local IP if needed
# LOCAL_IP=192.168.0.181

# Domain for dev environment (default: green-ecolution.dev)
# DOMAIN=green-ecolution.dev

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Keycloak OIDC
GE_AUTH_OIDC_FRONTEND_CLIENT_ID=frontend
GE_AUTH_OIDC_FRONTEND_CLIENT_SECRET=EJogoaQSrW7vlo9CK3zIo2ieC8guy9Mm
GE_AUTH_OIDC_BACKEND_CLIENT_ID=backend
GE_AUTH_OIDC_BACKEND_CLIENT_SECRET=cVBGgWNlbwSLydLZfZMvTvmNCeiSmLGP

# S3 / MinIO
GE_S3_ACCESSKEY=root
