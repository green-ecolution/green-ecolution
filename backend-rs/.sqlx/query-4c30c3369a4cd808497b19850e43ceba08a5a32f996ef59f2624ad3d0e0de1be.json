  "query": "INSERT INTO sensors (id, status, latitude, longitude, geometry, provider, additional_informations)\n            VALUES ($1, $2, $3, $4, ST_SetSRID(ST_MakePoint($4, $3), 4326), $5, $6)\n            RETURNING id,\n                      status AS \"status: SensorStatus\",\n                      latitude, longitude,\n                      provider,\n                      additional_informations AS additional_info",
