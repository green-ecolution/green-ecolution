  "query": "SELECT id, created_at, updated_at,\n                      status AS \"status: SensorStatus\",\n                      latitude, longitude,\n                      provider,\n                      additional_informations AS additional_info\n            FROM sensors\n            WHERE ($1::text IS NULL OR provider = $1)\n            ORDER BY id\n            LIMIT $2 OFFSET $3",
